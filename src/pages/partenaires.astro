---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import PartnersRow from '@/components/PartnersRow.astro';
import TchaoMegot from '@/components/TchaoMegot.astro';
import Press from '@/components/Press.astro';
import RevealScript from '@/components/RevealScript.astro';
---

<BaseLayout title="Partenaires" description="Les partenaires et bénéficiaires du Clean Up Fest.">
  <PageHero
    eyebrow="Partenaires & presse"
    title="Les acteurs de l'événement."
    desc="World Cleanup Day, Tchao Mégot, We love Green, la ville de Lille et bien d'autres sont à nos côtés."
    photo="/media/photos/ai/volunteers-team-lille.jpg"
  />
  <PartnersRow />
  <TchaoMegot />
  <Press />

  <section class="container-page py-24 lg:py-32">
    <div class="grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <span class="eyebrow">Devenir partenaire</span>
        <h2 class="mt-3">Vous voulez<br/>nous rejoindre ?</h2>
        <p class="mt-4 text-ink-muted leading-relaxed">
          Nous cherchons des partenaires ancrés localement pour l'édition 2026 :
          brasseries, foodtrucks, marques équipement, presse spécialisée, artistes locaux.
        </p>
        <a href="mailto:partenaires@cleanupfest.fr" class="btn btn-primary mt-6">Écrire à l'équipe</a>
      </div>
      <div class="md:col-span-7 grid sm:grid-cols-2 gap-4">
        {[
          { titre: 'Sponsor officiel', desc: 'Naming, présence hero, kit exclusif.', tag: 'Premium' },
          { titre: 'Partenaire équipement', desc: 'Chaussures, textile, accessoires.', tag: 'Sport' },
          { titre: 'Partenaire food/bev', desc: 'Foodtruck, bière, boissons.', tag: 'F&B' },
          { titre: 'Média partenaire', desc: 'Couverture éditoriale, live sur place.', tag: 'Media' },
        ].map((it) => (
          <div class="card p-6">
            <span class="chip">{it.tag}</span>
            <h3 class="mt-3">{it.titre}</h3>
            <p class="text-sm text-ink-muted mt-2">{it.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <RevealScript />
</BaseLayout>
