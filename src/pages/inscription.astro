---
import BaseLayout from '@/layouts/BaseLayout.astro';
import InscriptionForm from '@/components/InscriptionForm.astro';
import { site } from '@/data/site';
---

<BaseLayout title="Inscription" description="Inscrivez-vous au Clean Up Fest." hideTicketBar>
  <section class="grid md:grid-cols-12 min-h-[calc(100svh-80px)]">
    <!-- Photo side -->
    <div class="md:col-span-5 relative min-h-[220px] md:min-h-full order-2 md:order-1">
      <img src="/media/photos/running-crowd.jpg" alt="" class="absolute inset-0 w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-black/40"></div>
      <div class="absolute inset-0 p-8 md:p-12 flex flex-col justify-end text-white">
        <div>
          <div class="font-display text-4xl md:text-5xl font-semibold leading-tight">
            {site.dateAffichee}
          </div>
          <div class="mt-2 text-white/85 text-sm uppercase tracking-widest">
            {site.lieu} · {site.horaires}
          </div>
          <ul class="mt-6 space-y-2 text-sm text-white/85">
            <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-accent"></span>Sacs & gants fournis</li>
            <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-accent"></span>Bière offerte à l'arrivée</li>
            <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-accent"></span>DJ set toute la journée</li>
            <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-accent"></span>100% des bénéfices reversés à World Cleanup Day</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Form side -->
    <div class="md:col-span-7 order-1 md:order-2 py-14 sm:py-20">
      <div class="container-page">
        <span class="eyebrow">Inscription</span>
        <h1 class="mt-3 max-w-lg">Rejoignez le mouvement.</h1>
        <p class="mt-3 text-ink-muted max-w-md">
          Un formulaire simple, une confirmation par email dès l'ouverture officielle.
        </p>

        <div class="mt-10 max-w-2xl">
          <InscriptionForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
