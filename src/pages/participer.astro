---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import GoogleMap from '@/components/GoogleMap.astro';
import AudienceCards from '@/components/AudienceCards.astro';
import PracticalInfo from '@/components/PracticalInfo.astro';
import Faq from '@/components/Faq.astro';
import RevealScript from '@/components/RevealScript.astro';
---

<BaseLayout title="Participer" description="Formules marche/course, parcours interactif, infos pratiques et FAQ pour participer au Clean Up Fest à Lille.">
  <PageHero
    eyebrow="Participer"
    title="Marche, course, parcours."
    desc="Choisissez votre formule, découvrez le tracé et les infos pratiques."
    photo="/media/photos/ai/runners-lille-street.jpg"
  />

  <!-- Étape 1+2 fusionnées : choisir sa formule + voir le parcours -->
  <GoogleMap />

  <!-- Étape 3 : trouver son profil (audiences) -->
  <AudienceCards />

  <!-- Étape 4 : infos pratiques -->
  <PracticalInfo />

  <!-- FAQ pour dernières questions -->
  <Faq />

  <RevealScript />
</BaseLayout>
