---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import Manifesto from '@/components/Manifesto.astro';
import Programme from '@/components/Programme.astro';
import Aftermovie from '@/components/Aftermovie.astro';
import KpiBlock from '@/components/KpiBlock.astro';
import Testimonials from '@/components/Testimonials.astro';
import Faq from '@/components/Faq.astro';
import RevealScript from '@/components/RevealScript.astro';
import { storyboard, site } from '@/data/site';
---

<BaseLayout title="Le festival" description="Le concept et le déroulé d'une journée Clean Up Fest.">
  <PageHero
    eyebrow="Le festival"
    title="Nettoyer Lille en dansant."
    desc={site.valeur}
    photo="/media/photos/festival-lights.jpg"
  />

  <Manifesto />

  <section class="container-page py-24 lg:py-32">
    <div class="grid md:grid-cols-12 gap-10 items-start">
      <div class="md:col-span-4 md:sticky md:top-24">
        <span class="eyebrow">Le storyboard</span>
        <h2 class="mt-3">Comment ça<br/>se passe ?</h2>
      </div>
      <ol class="md:col-span-8 relative border-l-2 border-primary/25 pl-8 space-y-8">
        {storyboard.map((step, i) => (
          <li class="relative reveal">
            <span class="absolute -left-[42px] top-0 w-9 h-9 rounded-full bg-primary text-white font-mono font-semibold flex items-center justify-center text-sm">
              {(i + 1).toString().padStart(2, '0')}
            </span>
            <p class="text-ink leading-relaxed">{step}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <Aftermovie youtubeId="wLQMc32ttX8" />
  <Programme />
  <KpiBlock />
  <Testimonials />
  <Faq />
  <RevealScript />
</BaseLayout>
