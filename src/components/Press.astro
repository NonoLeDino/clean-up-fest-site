---
import { press } from '@/data/site';
---

<section class="section-dark">
  <div class="container-page py-20 lg:py-24">
    <div class="grid md:grid-cols-12 gap-8 items-end mb-10">
      <div class="md:col-span-8">
        <span class="eyebrow !text-white/60">Ils en ont parlé</span>
        <h2 class="mt-3 text-white">La presse en parle.</h2>
      </div>
      <span
        class="md:col-span-4 md:justify-self-end btn btn-ghost !opacity-60 !cursor-not-allowed"
        aria-disabled="true"
        title="Le kit presse sera disponible prochainement"
      >
        Kit presse
        <span class="ml-1 text-[10px] font-mono uppercase tracking-widest opacity-70">— bientôt</span>
      </span>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4 reveal-group">
      {press.map((p) => (
        <figure class="border-t border-white/15 pt-6 reveal">
          <div class="font-display font-semibold text-white text-xl mb-2">{p.nom}</div>
          <blockquote class="text-white/85 text-sm leading-relaxed">{p.citation}</blockquote>
          <div class="mt-4 eyebrow !text-white/50">{p.date}</div>
        </figure>
      ))}
    </div>
  </div>
</section>
