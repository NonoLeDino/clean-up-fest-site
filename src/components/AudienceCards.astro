---
import { audiences } from '@/data/site';

const bg: Record<string, string> = {
  ecole:        '/media/photos/volunteer.jpg',
  entreprise:   '/media/photos/talk.jpg',
  collectivite: '/media/photos/beach-cleanup.jpg',
  particulier:  '/media/photos/running-crowd.jpg',
};
---

<section class="container-page py-24 lg:py-32">
  <div class="grid md:grid-cols-12 gap-8 items-end mb-12">
    <div class="md:col-span-8">
      <span class="eyebrow">Vous êtes ?</span>
      <h2 class="mt-3">Trouvez votre<br/>porte d'entrée.</h2>
    </div>
    <p class="md:col-span-4 text-ink-muted">
      Quatre profils, quatre parcours d'inscription — un seul terrain de jeu.
    </p>
  </div>

  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 reveal-group">
    {audiences.map((a, i) => (
      <a
        href={`/participer#${a.id}`}
        class="relative aspect-[3/4] rounded-lg overflow-hidden cursor-pointer group isolate reveal"
      >
        <img src={bg[a.id]} alt="" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" aria-hidden="true"/>
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/10"></div>
        <div class="absolute inset-0 p-6 flex flex-col justify-between text-white">
          <span class="font-mono text-[11px] opacity-70">0{i + 1} / 04</span>
          <div>
            <h3 class="font-display text-3xl font-semibold !leading-none mb-3">{a.titre}</h3>
            <p class="text-sm text-white/85 leading-relaxed">{a.pitch}</p>
            <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold group-hover:gap-3 transition-all">
              {a.cta}
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
