---
import { site } from '@/data/site';

// Splits the statement into words for word-by-word reveal
const highlightRe = /(dansant|courant)/gi;
---

<section class="relative section-cream overflow-hidden isolate">
  <!-- Rotating badge -->
  <div aria-hidden="true" class="absolute top-16 right-8 md:top-24 md:right-16 lg:right-24 pointer-events-none">
    <div class="relative w-32 h-32 md:w-40 md:h-40 spin-slow">
      <svg viewBox="0 0 200 200" class="w-full h-full">
        <defs>
          <path id="badgeCircle" d="M 100,100 m -78,0 a 78,78 0 1,1 156,0 a 78,78 0 1,1 -156,0"/>
        </defs>
        <text font-family="var(--font-mono)" font-size="14" fill="var(--color-primary-dark)" letter-spacing="4">
          <textPath href="#badgeCircle" startOffset="0">
            CLEAN UP FEST ✦ ÉDITION 2026 ✦ CLEAN UP FEST ✦ ÉDITION 2026 ✦
          </textPath>
        </text>
      </svg>
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="w-14 h-14 md:w-16 md:h-16 rounded-full bg-accent flex items-center justify-center shadow-glow">
          <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <div class="container-page py-28 md:py-36 relative">
    <div class="grid md:grid-cols-12 gap-10 items-start">
      <!-- Left : title + photo collage -->
      <div class="md:col-span-5 flex flex-col gap-10">
        <div class="reveal">
          <span class="eyebrow">Manifeste · 01</span>
          <h2 class="mt-3 text-[3rem] md:text-[3.75rem] leading-[0.95] !normal-case">
            Une journée<br/>
            <span class="italic font-normal text-primary">pour changer</span><br/>
            de rythme.
          </h2>
        </div>

        <!-- Photo collage stacked -->
        <div class="relative aspect-[4/5] max-w-sm reveal">
          <div class="absolute top-0 left-6 w-56 md:w-64 aspect-[3/4] rounded-lg overflow-hidden shadow-2xl rotate-[-4deg] border-4 border-bg">
            <img src="/media/photos/cleanup-hands.jpg" alt="" class="w-full h-full object-cover" loading="lazy"/>
          </div>
          <div class="absolute bottom-4 right-0 w-56 md:w-64 aspect-[3/4] rounded-lg overflow-hidden shadow-2xl rotate-[5deg] border-4 border-bg">
            <img src="/media/photos/running-crowd.jpg" alt="" class="w-full h-full object-cover" loading="lazy"/>
          </div>
          <div class="absolute top-24 -right-4 w-40 md:w-48 aspect-square rounded-full overflow-hidden shadow-2xl border-4 border-bg z-10">
            <img src="/media/photos/dj-console.jpg" alt="" class="w-full h-full object-cover" loading="lazy"/>
          </div>
          <!-- Tag stickers -->
          <div class="absolute -top-3 -left-3 chip !bg-accent !text-white shadow-lg rotate-[-8deg]">
            <span class="w-1.5 h-1.5 rounded-full bg-white"></span>
            Édition 2025
          </div>
          <div class="absolute bottom-8 -left-2 chip !bg-primary !text-white shadow-lg rotate-[4deg]">
            2 340 kg
          </div>
        </div>
      </div>

      <!-- Right : statement + 3 pillars -->
      <div class="md:col-span-7 md:pl-6 flex flex-col gap-14">
        <!-- Big statement with animated reveal -->
        <div class="reveal">
          <svg class="w-14 h-14 text-accent mb-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9 7c-3 1-5 3.5-5 7v3h6v-6H7c0-2 1-3.5 3-4V7zm10 0c-3 1-5 3.5-5 7v3h6v-6h-3c0-2 1-3.5 3-4V7z"/>
          </svg>
          <p class="statement font-display text-[2.2rem] md:text-[2.75rem] leading-[1.05] tracking-[-0.02em] text-ink text-balance">
            Nettoyer la ville en <span class="hl hl-pink">dansant</span>.
            Ramasser en <span class="hl hl-green">courant</span>.
            Faire la fête en agissant.
            <span class="text-ink-muted">Pas de leçon. Pas de morale. Juste une journée où {site.ville} respire.</span>
          </p>
        </div>

        <!-- 3 pillars redesigned -->
        <ul class="grid sm:grid-cols-3 gap-4 pt-8 border-t border-border reveal-group">
          {[
            { chiffre: '01', titre: 'Ramasser', desc: 'Sacs & gants fournis. On travaille en équipe, on rigole en marchant.', icon: 'M6 3h12l1 4H5l1-4z M4 7h16v13a2 2 0 01-2 2H6a2 2 0 01-2-2V7z M10 12h4' },
            { chiffre: '02', titre: 'Bouger',   desc: 'Marche 3 km ou course 10 km chronométrée. Deux ambiances, un DJ.', icon: 'M13 4a2 2 0 100-4 2 2 0 000 4zm-1 12l-3 3-2 3 M15 8l-3 6 4 4' },
            { chiffre: '03', titre: 'Fêter',    desc: "Foodtrucks, DJ set jusqu'à 22h, une bière offerte à l'arrivée.",   icon: 'M17 8h1a4 4 0 010 8h-1 M3 8h14v9a4 4 0 01-4 4H7a4 4 0 01-4-4V8z M6 4v2 M10 4v2 M14 4v2' },
          ].map((it) => (
            <li class="reveal group relative rounded-lg bg-white border border-border p-6 hover:border-primary/40 transition-all hover:-translate-y-1 duration-300 cursor-pointer">
              <div class="flex items-start justify-between mb-4">
                <div class="w-11 h-11 rounded-full bg-primary-soft flex items-center justify-center group-hover:bg-accent transition-colors">
                  <svg class="w-5 h-5 text-primary group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d={it.icon}/>
                  </svg>
                </div>
                <span class="font-mono text-xs text-ink-muted">{it.chiffre} / 03</span>
              </div>
              <div class="font-display text-2xl text-primary font-semibold">{it.titre}</div>
              <div class="text-sm text-ink-muted mt-2 leading-relaxed">{it.desc}</div>
            </li>
          ))}
        </ul>

        <div class="flex flex-wrap items-center gap-6 reveal">
          <a href="/le-festival" class="btn btn-outline">
            Lire tout le manifeste
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
          <div class="text-sm text-ink-muted">
            <span class="font-mono font-semibold text-ink">2 min</span> de lecture · rédigé par l'équipe fondatrice
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes spinSlow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .spin-slow { animation: spinSlow 22s linear infinite; }
  @media (prefers-reduced-motion: reduce) { .spin-slow { animation: none; } }

  /* Highlight underline animation */
  .hl {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }
  .hl::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.06em;
    width: 100%;
    height: 0.28em;
    border-radius: 4px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 900ms cubic-bezier(0.7, 0, 0.3, 1) 200ms;
  }
  .hl-pink { color: var(--color-accent); }
  .hl-pink::after { background: var(--color-accent); opacity: 0.25; }
  .hl-green { color: var(--color-primary); }
  .hl-green::after { background: var(--color-primary); opacity: 0.28; }
  .reveal.in-view .hl::after { transform: scaleX(1); }
</style>
