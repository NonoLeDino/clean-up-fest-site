---
import { routes, formules, gmapWaypoints, site } from '@/data/site';

/**
 * Section unifiée : Formule (Marche/Course) + Google Maps + Étapes chronométrées.
 * Un seul toggle contrôle : bullets formule, iframe map, stats, waypoints, CTA.
 */

const buildEmbed = (o: { origin: string; waypoints: readonly string[]; destination: string }) => {
  const daddr = [...o.waypoints, o.destination].map(encodeURIComponent).join('+to:');
  return `https://maps.google.com/maps?saddr=${encodeURIComponent(o.origin)}&daddr=${daddr}&dirflg=w&output=embed`;
};
const buildExt = (o: { origin: string; waypoints: readonly string[]; destination: string }) => {
  const wp = o.waypoints.map(encodeURIComponent).join('|');
  return `https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(o.origin)}&destination=${encodeURIComponent(o.destination)}&travelmode=walking&waypoints=${wp}`;
};

const embedUrls = { marche: buildEmbed(gmapWaypoints.marche), course: buildEmbed(gmapWaypoints.course) };
const extUrls   = { marche: buildExt(gmapWaypoints.marche),   course: buildExt(gmapWaypoints.course) };

const routeByFormule: Record<string, typeof routes[number]> = { marche: routes[0], course: routes[1] };
const formuleById: Record<string, typeof formules[number]> = { marche: formules[0], course: formules[1] };
---

<section id="map" class="container-page py-24 lg:py-32">
  <div class="grid md:grid-cols-12 gap-8 items-end mb-10">
    <div class="md:col-span-8">
      <span class="eyebrow">Formule & parcours · {site.ville}</span>
      <h2 class="mt-3">Choisis ton camp.</h2>
      <p class="mt-3 text-ink-muted max-w-md">
        Marche ou course : un seul choix qui définit ta formule, ton parcours et tes étapes.
      </p>
    </div>
    <div class="md:col-span-4 md:justify-self-end">
      <div id="route-toggle" role="tablist" aria-label="Choix de la formule"
           class="inline-flex items-center bg-cream border border-border rounded-full p-1">
        {routes.map((r, i) => (
          <button type="button" role="tab" data-route={r.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            data-active={i === 0 ? 'true' : 'false'}
            class="px-5 py-2 text-sm font-semibold rounded-full cursor-pointer transition-colors data-[active=true]:bg-ink data-[active=true]:text-white text-ink">
            <span class="w-2 h-2 rounded-full inline-block mr-2" style={`background:${r.couleur}`}></span>
            {r.label}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Stats row -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6 border-y border-border py-5">
    {routes.map((r, i) => (
      <div data-route-stats={r.id} class:list={['contents', i !== 0 && 'hidden']}>
        <div>
          <div class="eyebrow">Distance</div>
          <div class="font-display text-2xl font-semibold text-ink mt-1">{r.distance}</div>
        </div>
        <div>
          <div class="eyebrow">Durée moy.</div>
          <div class="font-display text-2xl font-semibold text-ink mt-1">{r.duree}</div>
        </div>
        <div>
          <div class="eyebrow">Dénivelé</div>
          <div class="font-display text-2xl font-semibold text-ink mt-1">{r.denivele}</div>
        </div>
        <div>
          <div class="eyebrow">Prix</div>
          <div class:list={['font-display text-2xl font-semibold mt-1', r.id === 'course' ? 'text-accent' : 'text-primary']}>
            {r.prix}
            {r.id === 'course' && <span class="ml-1 text-xs font-mono text-ink-muted uppercase tracking-widest">solidaire</span>}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Row : Google Maps + Formule details -->
  <div class="grid lg:grid-cols-12 gap-6">
    <!-- Google Maps iframe -->
    <div class="lg:col-span-7">
      <div class="relative aspect-[16/10] rounded-lg overflow-hidden border border-border shadow-card bg-cream">
        <iframe
          id="gmap-iframe"
          src={embedUrls.marche}
          title="Parcours Clean Up Fest — Grand Place → Citadelle de Lille"
          class="absolute inset-0 w-full h-full"
          style="border:0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>

        <a
          id="map-ext-link"
          href={extUrls.marche}
          target="_blank"
          rel="noopener noreferrer"
          class="absolute top-3 right-3 bg-white/95 backdrop-blur border border-border rounded-full px-4 py-2 text-sm font-semibold text-ink shadow-lg hover:bg-white transition-colors flex items-center gap-2"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 21c-4-3-8-6-8-11a8 8 0 1116 0c0 5-4 8-8 11z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          Voir sur Google Maps
        </a>
      </div>
    </div>

    <!-- Formule details -->
    <div class="lg:col-span-5">
      {formules.map((f, i) => (
        <div data-formule-info={f.id} class:list={['card p-6 sm:p-7 h-full flex flex-col', i !== 0 && 'hidden']}>
          <div class="flex items-start justify-between gap-4 mb-3">
            <h3 class="!text-3xl text-primary">{f.titre}</h3>
            <span class:list={['chip', f.id === 'course' ? 'chip-green' : 'chip-green']}>{f.prix}</span>
          </div>
          <p class="text-ink-muted mb-5 leading-relaxed">{f.desc}</p>
          <ul class="space-y-2.5 mb-6 flex-1">
            {f.bullets.map((b) => (
              <li class="flex items-start gap-2.5 text-sm">
                <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>
          <a href={`/inscription?formule=${f.id}`} class="btn btn-primary self-start">Je m'inscris</a>
        </div>
      ))}
    </div>
  </div>

  <!-- Étapes chronométrées -->
  <div class="mt-8 border-t border-border pt-8">
    <div class="flex items-end justify-between flex-wrap gap-4 mb-6">
      <div>
        <div class="eyebrow">Étapes du parcours</div>
        <h3 class="mt-2 !text-2xl">Ce qui t'attend en route.</h3>
      </div>
      <div id="stops-count" class="font-mono text-sm text-ink-muted">— étapes</div>
    </div>
    {routes.map((r, ri) => (
      <ol data-route-stops={r.id} class:list={['grid gap-2 sm:grid-cols-2 lg:grid-cols-4', ri !== 0 && 'hidden']}>
        {r.points.map((p, i) => (
          <li class="border border-border rounded-lg p-4 hover:border-primary/40 transition-colors">
            <div class="flex items-baseline justify-between gap-2 mb-1.5">
              <span class="w-6 h-6 rounded-full inline-flex items-center justify-center font-mono text-[10px] font-bold text-white" style={`background:${r.couleur}`}>{i + 1}</span>
              <span class="font-mono text-xs text-accent tabular-nums font-semibold">{p.horaires}</span>
            </div>
            <div class="font-semibold text-ink text-sm leading-tight">{p.titre.replace('· ', '')}</div>
            <div class="text-xs text-ink-muted mt-1 leading-relaxed">{p.desc}</div>
          </li>
        ))}
      </ol>
    ))}
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-4 justify-between border-t border-border pt-6">
    <div class="text-sm text-ink-muted">
      Départ village <span class="font-semibold text-ink">Grand Place, Lille</span> · Métro Rihour (ligne 1) · Parkings à proximité
    </div>
    <a href="/inscription" class="btn btn-primary !py-2.5">Je m'inscris</a>
  </div>
</section>

<script is:inline define:vars={{ embedUrls, extUrls }}>
  const toggle = document.getElementById('route-toggle');
  const tabs = toggle?.querySelectorAll('[data-route]');
  const iframe = document.getElementById('gmap-iframe');
  const extLink = document.getElementById('map-ext-link');
  const stopsCount = document.getElementById('stops-count');
  const counts = { marche: 4, course: 7 };

  const showRoute = (id) => {
    tabs?.forEach((t) => {
      const active = t.getAttribute('data-route') === id;
      t.setAttribute('data-active', active ? 'true' : 'false');
      t.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    document.querySelectorAll('[data-route-stats]').forEach((el) => el.classList.toggle('hidden', el.getAttribute('data-route-stats') !== id));
    document.querySelectorAll('[data-formule-info]').forEach((el) => el.classList.toggle('hidden', el.getAttribute('data-formule-info') !== id));
    document.querySelectorAll('[data-route-stops]').forEach((el) => el.classList.toggle('hidden', el.getAttribute('data-route-stops') !== id));
    if (iframe) iframe.src = embedUrls[id];
    if (extLink) extLink.href = extUrls[id];
    if (stopsCount) stopsCount.textContent = `${counts[id]} étapes`;
  };
  tabs?.forEach((t) => t.addEventListener('click', () => showRoute(t.getAttribute('data-route'))));
  showRoute('marche');
</script>
