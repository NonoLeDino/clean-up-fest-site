---
import Logo from './Logo.astro';
import { nav } from '@/data/site';
---

<!-- Scroll progress bar -->
<div id="scroll-progress" aria-hidden="true"
     class="fixed top-0 left-0 right-0 z-50 h-[3px] bg-accent scale-x-0 origin-left transition-transform duration-100"
     style="transform-origin: left;"></div>

<header id="site-header" class="fixed top-0 left-0 right-0 z-40 transition-[transform,background-color,padding,box-shadow,backdrop-filter] duration-300 will-change-transform pt-4 sm:pt-6">
  <div class="container-page">
    <div class="flex items-center justify-between gap-4">

      <!-- LEFT : Logo only -->
      <a href="/" aria-label="Clean Up Fest — Accueil" class="shrink-0">
        <Logo variant="green" size="sm" glow />
      </a>

      <!-- CENTER : Nav (desktop) -->
      <nav aria-label="Navigation principale" class="hidden lg:flex items-center gap-1">
        {nav.map((item) => (
          <a
            href={item.href}
            data-nav-link
            class="group relative px-3.5 py-2 rounded-full text-sm font-semibold whitespace-nowrap transition-colors cursor-pointer text-white/95 hover:text-white"
          >
            <span class="relative z-10">{item.label}</span>
            <span aria-hidden="true"
                  class="absolute inset-x-3 bottom-1 h-[2px] bg-current scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-300"></span>
          </a>
        ))}
      </nav>

      <!-- RIGHT : CTA -->
      <div class="flex items-center gap-2 shrink-0">
        <a href="/inscription"
           class="group relative bg-accent text-white rounded-full pl-5 pr-2 py-2 shadow-[0_8px_24px_rgba(255,0,127,0.32)] hover:shadow-[0_12px_32px_rgba(255,0,127,0.45)] transition-all duration-300 flex items-center gap-2 font-display font-semibold text-sm">
          <span>Je m'inscris</span>
          <span class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center group-hover:bg-white group-hover:text-accent transition-colors duration-300">
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </span>
        </a>

        <!-- Mobile menu -->
        <button
          type="button"
          id="mobile-menu-btn"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          data-mobile-btn
          class="lg:hidden inline-flex items-center justify-center w-11 h-11 rounded-full border border-white/40 text-white cursor-pointer"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="21" y2="17"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden container-page pb-4 mt-3">
    <div class="bg-white/95 backdrop-blur-xl border border-border rounded-lg overflow-hidden shadow-card">
      <nav class="flex flex-col divide-y divide-border" aria-label="Navigation mobile">
        {nav.map((item) => (
          <a href={item.href} class="px-5 py-4 text-base font-semibold text-ink hover:bg-primary-soft cursor-pointer">{item.label}</a>
        ))}
      </nav>
    </div>
  </div>
</header>


<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  });

  // Scroll: progress bar + color adapt + hide-on-scroll-down / show-on-scroll-up
  const progress = document.getElementById('scroll-progress');
  const header = document.getElementById('site-header');
  const links = document.querySelectorAll<HTMLElement>('[data-nav-link]');
  const mobileBtn = document.querySelector<HTMLElement>('[data-mobile-btn]');

  const setBg = (on: boolean) => {
    if (!header) return;
    header.classList.toggle('bg-white/95', on);
    header.classList.toggle('backdrop-blur-xl', on);
    header.classList.toggle('shadow-[0_6px_24px_rgba(20,33,26,0.06)]', on);
    header.classList.toggle('border-b', on);
    header.classList.toggle('border-border', on);
    header.classList.toggle('pt-4', !on);
    header.classList.toggle('sm:pt-6', !on);
    header.classList.toggle('py-3', on);
    header.classList.toggle('sm:py-4', on);
  };

  let lastY = window.scrollY;
  const onScroll = () => {
    const s = window.scrollY;
    const max = document.body.scrollHeight - window.innerHeight;
    const pct = Math.max(0, Math.min(1, s / Math.max(1, max)));
    if (progress) progress.style.transform = `scaleX(${pct})`;

    // Position tracking : transparent au top / hide-on-scroll-down / show-on-scroll-up avec bg blanc
    const atTop = s < 80;
    const delta = s - lastY;
    if (header) {
      if (atTop) {
        header.style.transform = 'translateY(0)';
      } else if (delta > 4) {
        header.style.transform = 'translateY(-110%)';
      } else if (delta < -4) {
        header.style.transform = 'translateY(0)';
      }
    }
    lastY = s;

    // Fond : transparent en haut, blanc quand on descend au-delà du hero
    setBg(!atTop);

    // Couleur texte : blanc sur hero (transparent bg), dark sur white bg
    const useWhiteText = atTop && s < (window.innerHeight * 0.75);
    links.forEach((l) => {
      l.classList.toggle('text-white/95', useWhiteText);
      l.classList.toggle('hover:text-white', useWhiteText);
      l.classList.toggle('text-ink', !useWhiteText);
      l.classList.toggle('hover:text-accent', !useWhiteText);
    });
    if (mobileBtn) {
      mobileBtn.classList.toggle('border-white/40', useWhiteText);
      mobileBtn.classList.toggle('text-white', useWhiteText);
      mobileBtn.classList.toggle('border-border', !useWhiteText);
      mobileBtn.classList.toggle('text-ink', !useWhiteText);
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
