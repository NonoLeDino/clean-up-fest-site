---
type Props = { youtubeId?: string };
const { youtubeId = 'dQw4w9WgXcQ' } = Astro.props;
---

<section class="section-dark relative overflow-hidden">
  <div class="container-page py-24 lg:py-32">
    <div class="grid md:grid-cols-12 gap-6 items-end mb-12">
      <div class="md:col-span-8">
        <span class="eyebrow !text-white/60">Aftermovie · Édition 2025</span>
        <h2 class="mt-3 text-white">Revivez la<br/>dernière édition.</h2>
      </div>
      <div class="md:col-span-4">
        <p class="text-white/70">1 500 participants. 2 340 kg ramassés. 8 heures de DJ. Une bière à l'arrivée. Un souvenir.</p>
      </div>
    </div>

    <button
      type="button"
      id="aftermovie-btn"
      data-youtube={youtubeId}
      class="relative w-full aspect-video rounded-lg overflow-hidden bg-black cursor-pointer group focus-visible:outline-accent"
      aria-label="Lancer l'aftermovie"
    >
      <img
        src="/media/video/aftermovie-poster.jpg"
        alt=""
        class="absolute inset-0 w-full h-full object-cover opacity-80 transition-all duration-500 group-hover:opacity-100 group-hover:scale-105"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/40"></div>

      <!-- Play button -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-full bg-accent flex items-center justify-center shadow-glow transition-transform duration-300 group-hover:scale-110">
          <svg class="w-9 h-9 sm:w-10 sm:h-10 text-white translate-x-0.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </div>
      </div>

      <!-- Corner labels -->
      <div class="absolute top-6 left-6 chip !bg-white/15 !text-white !border !border-white/25 backdrop-blur">
        <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
        02:34
      </div>
      <div class="absolute bottom-6 left-6 right-6 flex items-center justify-between text-white">
        <div class="font-display font-semibold text-2xl sm:text-3xl">Clean Up Fest · 2025</div>
        <div class="hidden sm:block font-mono text-xs uppercase tracking-widest text-white/70">4K · 25fps</div>
      </div>
    </button>
  </div>

  <!-- Modal video -->
  <div id="aftermovie-modal" class="hidden fixed inset-0 z-[60] bg-black/95 backdrop-blur-md items-center justify-center p-4">
    <button type="button" id="aftermovie-close" class="absolute top-6 right-6 w-11 h-11 rounded-full bg-white/10 border border-white/20 text-white hover:bg-white/20 cursor-pointer" aria-label="Fermer">
      <svg class="w-5 h-5 mx-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <div class="w-full max-w-5xl aspect-video rounded-lg overflow-hidden">
      <iframe id="aftermovie-iframe" class="w-full h-full" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('aftermovie-btn');
  const modal = document.getElementById('aftermovie-modal');
  const close = document.getElementById('aftermovie-close');
  const iframe = document.getElementById('aftermovie-iframe') as HTMLIFrameElement | null;

  const open = () => {
    if (!modal || !iframe || !btn) return;
    const id = btn.getAttribute('data-youtube');
    iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  };
  const shut = () => {
    if (!modal || !iframe) return;
    iframe.src = '';
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  };
  btn?.addEventListener('click', open);
  close?.addEventListener('click', shut);
  modal?.addEventListener('click', (e) => { if (e.target === modal) shut(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') shut(); });
</script>
