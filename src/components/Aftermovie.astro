---
type Props = { videoSrc?: string; poster?: string };
const {
  videoSrc = '/media/video/aftermovie.mp4',
  poster = '/media/photos/ai/aerial-march-grand-place.jpg',
} = Astro.props;
---

<section class="section-dark relative overflow-hidden">
  <div class="container-page py-24 lg:py-32">
    <div class="grid md:grid-cols-12 gap-6 items-end mb-12">
      <div class="md:col-span-8">
        <span class="eyebrow !text-white/60">Aftermovie · Édition 2025</span>
        <h2 class="mt-3 text-white">Revivez la<br/>dernière édition.</h2>
      </div>
      <div class="md:col-span-4">
        <p class="text-white/70">1 500 participants. 2 340 kg ramassés. 8 heures de DJ. Une bière à l'arrivée. Un souvenir.</p>
      </div>
    </div>

    <button
      type="button"
      id="aftermovie-btn"
      class="relative w-full aspect-video rounded-lg overflow-hidden bg-black cursor-pointer group focus-visible:outline-accent block"
      aria-label="Lancer l'aftermovie"
    >
      <!-- Preview video (muted, silent loop) -->
      <video
        id="aftermovie-preview"
        class="absolute inset-0 w-full h-full object-cover"
        muted
        loop
        playsinline
        preload="metadata"
        poster={poster}
      >
        <source src={videoSrc} type="video/mp4">
      </video>
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-black/40 pointer-events-none"></div>

      <!-- Titre en bas -->
      <div class="absolute bottom-6 left-6 right-6 text-white pointer-events-none">
        <div class="font-display font-semibold text-2xl sm:text-3xl">Clean Up Fest · 2025</div>
      </div>
    </button>
  </div>

  <!-- Modal fullscreen -->
  <div id="aftermovie-modal" class="hidden fixed inset-0 z-[60] bg-black/95 backdrop-blur-md items-center justify-center p-4">
    <button type="button" id="aftermovie-close" class="absolute top-6 right-6 w-11 h-11 rounded-full bg-white/10 border border-white/20 text-white hover:bg-white/20 cursor-pointer" aria-label="Fermer">
      <svg class="w-5 h-5 mx-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <video id="aftermovie-full" class="w-full max-w-5xl aspect-video rounded-lg" controls playsinline>
      <source src={videoSrc} type="video/mp4">
    </video>
  </div>
</section>

<script>
  const btn = document.getElementById('aftermovie-btn');
  const modal = document.getElementById('aftermovie-modal');
  const close = document.getElementById('aftermovie-close');
  const full = document.getElementById('aftermovie-full') as HTMLVideoElement | null;
  const preview = document.getElementById('aftermovie-preview') as HTMLVideoElement | null;
  const time = document.getElementById('aftermovie-time');

  // Play preview quietly on hover
  btn?.addEventListener('mouseenter', () => { preview?.play().catch(() => {}); });
  btn?.addEventListener('mouseleave', () => { preview?.pause(); if (preview) preview.currentTime = 0; });

  // Update time chip from preview
  preview?.addEventListener('loadedmetadata', () => {
    if (time && preview.duration) {
      const s = Math.floor(preview.duration);
      time.textContent = `${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`;
    }
  });

  const open = () => {
    if (!modal || !full) return;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    full.play().catch(() => {});
  };
  const shut = () => {
    if (!modal || !full) return;
    full.pause();
    full.currentTime = 0;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  };
  btn?.addEventListener('click', open);
  close?.addEventListener('click', shut);
  modal?.addEventListener('click', (e) => { if (e.target === modal) shut(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') shut(); });
</script>
