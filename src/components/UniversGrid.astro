---
import { univers } from '@/data/site';

const tint: Record<string, string> = {
  green: 'from-primary/85 via-primary/40',
  pink:  'from-accent/85 via-accent/40',
  dark:  'from-black/85 via-black/40',
  cream: 'from-ink/70 via-ink/30',
};

const icons: Record<string, string> = {
  leaf:   'M6 3v18M6 3c8 0 14 6 14 14v0c-8 0-14-6-14-14z',
  music:  'M9 18V5l12-2v13 M9 18a3 3 0 11-6 0 3 3 0 016 0zm12-2a3 3 0 11-6 0 3 3 0 016 0z',
  run:    'M13 4a2 2 0 100-4 2 2 0 000 4zm-1 12l-3 3-2 3 M15 8l-3 6 4 4 M6 12l4-3 5 3',
  cup:    'M17 8h1a4 4 0 010 8h-1 M3 8h14v9a4 4 0 01-4 4H7a4 4 0 01-4-4V8z M6 4v2 M10 4v2 M14 4v2',
  mic:    'M12 1a3 3 0 013 3v8a3 3 0 11-6 0V4a3 3 0 013-3z M19 10v2a7 7 0 11-14 0v-2 M12 19v4 M8 23h8',
  people: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2 M9 11a4 4 0 100-8 4 4 0 000 8z M23 21v-2a4 4 0 00-3-3.87 M16 3.13a4 4 0 010 7.75',
};
---

<section class="container-page py-24 lg:py-32">
  <div class="grid md:grid-cols-12 gap-8 items-end mb-12">
    <div class="md:col-span-8">
      <span class="eyebrow">Le festival, six univers</span>
      <h2 class="mt-3 max-w-2xl">Un festival, six mondes qui se croisent.</h2>
    </div>
    <p class="md:col-span-4 text-ink-muted text-lg leading-relaxed">
      Musique, sport, bouffe, causes. Une journée entière, six terrains de jeu qui s'entrelacent.
    </p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 reveal-group">
    {univers.map((u, i) => (
      <a
        href={`#${u.id}`}
        class="group relative aspect-[4/5] lg:aspect-[4/4.4] rounded-lg overflow-hidden cursor-pointer isolate reveal"
      >
        <img
          src={u.photo}
          alt={u.titre}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
        />
        <div class:list={['absolute inset-0 bg-gradient-to-t to-transparent', tint[u.couleur]]}></div>
        <div class="absolute inset-0 p-6 sm:p-7 flex flex-col justify-between text-white">
          <div class="flex items-start justify-between">
            <span class="font-mono text-[11px] opacity-80">0{i + 1} / 06</span>
            <svg class="w-7 h-7 opacity-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={icons[u.icon]}/>
            </svg>
          </div>
          <div>
            <div class="font-display font-semibold text-4xl sm:text-5xl leading-[0.95] tracking-tight mb-3">
              {u.titre}
            </div>
            <p class="text-sm text-white/85 max-w-xs leading-relaxed">{u.desc}</p>
            <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold opacity-90 group-hover:gap-3 transition-all">
              Découvrir
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
