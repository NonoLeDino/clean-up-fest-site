---
import { kpis } from '@/data/site';

const formatFR = (v: string) => {
  const n = Number(v);
  if (isNaN(n)) return v;
  return n.toLocaleString('fr-FR');
};
---

<section class="relative isolate overflow-hidden">
  <img src="/media/photos/beach-cleanup.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" aria-hidden="true"/>
  <div class="absolute inset-0 bg-primary/85 mix-blend-multiply"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-primary-dark/40 via-transparent to-primary/50"></div>

  <div class="relative container-page py-24 lg:py-32 text-white">
    <div class="grid md:grid-cols-12 gap-8 items-end mb-14">
      <div class="md:col-span-8">
        <span class="eyebrow !text-white/60">Impact · Édition 2025</span>
        <h2 class="mt-3 text-white">Nos chiffres.<br/>Notre trace.</h2>
      </div>
      <p class="md:col-span-4 text-white/85 leading-relaxed">
        Toutes les données sont vérifiées et publiées 30 jours après l'événement. Compte-rendu financier public.
      </p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 reveal-group">
      {kpis.map((k, i) => (
        <div class="border-l-4 border-accent pl-5 py-2 reveal">
          <div class="flex items-baseline gap-1">
            <span
              class="kpi-count font-display font-semibold text-white leading-none text-4xl sm:text-5xl lg:text-6xl tabular-nums"
              data-target={k.valeur}
              data-duration={1600 + i * 150}
            >{formatFR(k.valeur)}</span>
            {i === 2 && <span class="font-display font-semibold text-3xl sm:text-4xl text-white/80">€</span>}
          </div>
          <div class="mt-3 text-sm text-white uppercase tracking-widest font-semibold">
            {k.label}
          </div>
          {k.sub && <div class="mt-1 text-xs text-white/60">{k.sub}</div>}
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);
  const formatFr = (n: number) => n.toLocaleString('fr-FR');

  const animate = (el: HTMLElement) => {
    const target = Number(el.getAttribute('data-target') || '0');
    const duration = Number(el.getAttribute('data-duration') || '1500');
    const start = performance.now();
    const tick = (now: number) => {
      const t = Math.min(1, (now - start) / duration);
      const eased = easeOutCubic(t);
      const value = Math.round(target * eased);
      el.textContent = formatFr(value);
      if (t < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };

  const els = document.querySelectorAll<HTMLElement>('.kpi-count');
  const prefersReducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;

  if (prefersReducedMotion) {
    // Rendu final direct, pas d'animation
    els.forEach((el) => {
      const target = Number(el.getAttribute('data-target') || '0');
      el.textContent = formatFr(target);
    });
  } else if ('IntersectionObserver' in window) {
    // Reset à 0 puis anime au scroll dans la vue
    els.forEach((el) => (el.textContent = '0'));
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          animate(e.target as HTMLElement);
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.4 });
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach((el) => animate(el));
  }
</script>
