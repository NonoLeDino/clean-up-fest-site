---
type Props = { preview?: boolean };
const { preview = false } = Astro.props;
---

<section class="container-page py-24">
  <div class="flex items-end justify-between flex-wrap gap-4 mb-10">
    <div>
      <span class="chip">Parcours</span>
      <h2 class="mt-4">La map du festival.</h2>
      <p class="text-ink-muted mt-2 max-w-md">
        Un tracé au cœur de Lille — carte interactive à venir (Leaflet / Mapbox).
      </p>
    </div>
    {preview && <a href="/parcours" class="btn btn-outline">Voir le parcours</a>}
  </div>

  <div class="relative aspect-[16/8] rounded-lg overflow-hidden bg-primary-soft border border-border">
    <div aria-hidden="true" class="absolute inset-0 opacity-40 bg-[radial-gradient(circle_at_1px_1px,var(--color-primary)_1px,transparent_0)] [background-size:24px_24px]"></div>
    <svg class="absolute inset-0 w-full h-full" viewBox="0 0 800 400" preserveAspectRatio="none" aria-hidden="true">
      <path d="M60 320 C 150 240, 260 340, 360 220 S 600 120, 740 80"
            stroke="var(--color-accent)" stroke-width="4" stroke-dasharray="10 8" fill="none" stroke-linecap="round"/>
      <circle cx="60" cy="320" r="10" fill="var(--color-primary)"/>
      <circle cx="360" cy="220" r="8" fill="var(--color-accent)"/>
      <circle cx="740" cy="80" r="10" fill="var(--color-accent)"/>
    </svg>
    <div class="absolute bottom-4 left-4 right-4 flex justify-between text-xs font-semibold text-primary flex-wrap gap-2">
      <span class="bg-white/95 backdrop-blur px-3 py-1.5 rounded-full">Départ · Grand Place</span>
      <span class="bg-white/95 backdrop-blur px-3 py-1.5 rounded-full hidden sm:inline">Étape · Vauban</span>
      <span class="bg-white/95 backdrop-blur px-3 py-1.5 rounded-full">Arrivée · Citadelle</span>
    </div>
  </div>
</section>
