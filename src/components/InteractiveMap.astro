---
import { routes } from '@/data/site';
---

<section id="map" class="container-page py-24 lg:py-32">
  <div class="grid md:grid-cols-12 gap-8 items-end mb-10">
    <div class="md:col-span-8">
      <span class="eyebrow">Parcours interactif</span>
      <h2 class="mt-3">La map du festival.</h2>
      <p class="mt-3 text-ink-muted max-w-md">
        Basculez entre marche et course pour explorer les tracés,
        points de ravitaillement et étapes clés. Cliquez sur un point pour les détails.
      </p>
    </div>

    <!-- Toggle -->
    <div class="md:col-span-4 md:justify-self-end">
      <div id="route-toggle" role="tablist" aria-label="Choix du parcours"
           class="inline-flex items-center bg-cream border border-border rounded-full p-1">
        {routes.map((r, i) => (
          <button
            type="button"
            role="tab"
            data-route={r.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            data-active={i === 0 ? 'true' : 'false'}
            class="px-5 py-2 text-sm font-semibold rounded-full cursor-pointer transition-colors data-[active=true]:bg-ink data-[active=true]:text-white text-ink"
          >
            <span class="w-2 h-2 rounded-full inline-block mr-2" style={`background:${r.couleur}`}></span>
            {r.label}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Stats row -->
  <div id="route-stats" class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6 border-y border-border py-5">
    {routes.map((r, i) => (
      <div data-route-stats={r.id} class:list={['contents', i !== 0 && 'hidden']}>
        <div>
          <div class="eyebrow">Distance</div>
          <div class="font-display text-2xl font-semibold text-ink mt-1">{r.distance}</div>
        </div>
        <div>
          <div class="eyebrow">Durée moy.</div>
          <div class="font-display text-2xl font-semibold text-ink mt-1">{r.duree}</div>
        </div>
        <div>
          <div class="eyebrow">Dénivelé</div>
          <div class="font-display text-2xl font-semibold text-ink mt-1">{r.denivele}</div>
        </div>
        <div>
          <div class="eyebrow">Prix</div>
          <div class:list={['font-display text-2xl font-semibold mt-1', r.id === 'course' ? 'text-accent' : 'text-primary']}>
            {r.prix}
            {r.id === 'course' && <span class="ml-1 text-xs font-mono text-ink-muted uppercase tracking-widest">solidaire</span>}
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="grid md:grid-cols-12 gap-6">
    <!-- Map SVG -->
    <div class="md:col-span-8">
      <div class="relative aspect-[16/10] rounded-lg overflow-hidden bg-primary-soft border border-border">
        <!-- Dotted background -->
        <div aria-hidden="true" class="absolute inset-0 opacity-40 bg-[radial-gradient(circle_at_1px_1px,var(--color-primary)_1px,transparent_0)] [background-size:20px_20px]"></div>

        <!-- River Deûle (decorative) -->
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 100 62.5" preserveAspectRatio="none" aria-hidden="true">
          <path d="M 0 30 C 15 42, 30 20, 50 34 S 80 46, 100 40"
                stroke="rgba(56,132,182,0.28)" stroke-width="3" fill="none" stroke-linecap="round"/>
          <path d="M 0 30 C 15 42, 30 20, 50 34 S 80 46, 100 40"
                stroke="rgba(56,132,182,0.55)" stroke-width="1" fill="none" stroke-linecap="round"/>
        </svg>

        <!-- Grid lines (streets) -->
        <svg class="absolute inset-0 w-full h-full opacity-25" viewBox="0 0 100 62.5" preserveAspectRatio="none" aria-hidden="true">
          <g stroke="var(--color-primary-dark)" stroke-width="0.15">
            {[10,25,40,55,70,85].map((y) => <line x1="0" y1={y} x2="100" y2={y}/>)}
            {[10,25,40,55,70,85].map((x) => <line x1={x} y1="0" x2={x} y2="100"/>)}
          </g>
        </svg>

        <!-- Routes -->
        <svg id="route-svg" class="absolute inset-0 w-full h-full" viewBox="0 0 100 62.5" preserveAspectRatio="none" aria-hidden="true">
          {routes.map((r, i) => (
            <path
              data-route-path={r.id}
              d={r.path}
              stroke={r.couleur}
              stroke-width="1.2"
              stroke-dasharray="1.6 1.4"
              fill="none"
              stroke-linecap="round"
              class:list={[i !== 0 && 'hidden', 'transition-opacity duration-500']}
              style="filter: drop-shadow(0 2px 4px rgba(0,0,0,0.15));"
            />
          ))}
        </svg>

        <!-- Points -->
        {routes.map((r, ri) => (
          <div data-route-points={r.id} class:list={[ri !== 0 && 'hidden']}>
            {r.points.map((p, i) => (
              <button
                type="button"
                data-point={p.id}
                data-route={r.id}
                aria-label={p.titre}
                class="group absolute -translate-x-1/2 -translate-y-1/2 cursor-pointer focus-visible:outline-accent z-10"
                style={`left:${p.x}%; top:${p.y * (10/6.25)}%`}
              >
                {p.type === 'start' && (
                  <span class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-white shadow-lg group-hover:scale-110 transition-transform" style={`background:${r.couleur}`}>
                    <span class="font-mono text-[10px] font-bold text-white">A</span>
                  </span>
                )}
                {p.type === 'finish' && (
                  <span class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-white shadow-lg group-hover:scale-110 transition-transform bg-ink">
                    <span class="font-mono text-[10px] font-bold text-white">B</span>
                  </span>
                )}
                {p.type === 'village' && (
                  <span class="flex items-center justify-center w-8 h-8 rounded-full border-2 border-white shadow-md group-hover:scale-125 transition-transform bg-accent">
                    <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <circle cx="12" cy="12" r="4"/>
                    </svg>
                  </span>
                )}
                {p.type === 'checkpoint' && (
                  <span class="block w-4 h-4 rounded-full border-2 border-white shadow-md group-hover:scale-150 transition-transform" style={`background:${r.couleur}`}></span>
                )}
                <span class="absolute left-1/2 -translate-x-1/2 top-full mt-1 whitespace-nowrap text-[10px] font-mono text-ink font-semibold opacity-0 group-hover:opacity-100 transition-opacity bg-white/95 backdrop-blur px-2 py-0.5 rounded pointer-events-none">
                  {p.horaires}
                </span>
              </button>
            ))}
          </div>
        ))}

        <!-- Compass -->
        <div aria-hidden="true" class="absolute bottom-3 right-3 w-9 h-9 rounded-full bg-white/95 border border-border flex items-center justify-center font-mono text-[10px] text-ink font-bold">
          N ↑
        </div>

        <!-- Scale -->
        <div aria-hidden="true" class="absolute bottom-3 left-3 flex items-center gap-2 bg-white/95 border border-border rounded-full px-3 py-1">
          <div class="w-10 h-0.5 bg-ink"></div>
          <span class="font-mono text-[10px] text-ink">1 km</span>
        </div>
      </div>
    </div>

    <!-- Info panel -->
    <aside class="md:col-span-4 min-h-[300px]">
      {routes.map((r, ri) => (
        <div data-route-info={r.id} class:list={[ri !== 0 && 'hidden']}>
          <div class="card p-5 h-full">
            <div id={`info-${r.id}`} class="flex flex-col gap-4 h-full">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full" style={`background:${r.couleur}`}></span>
                <span class="eyebrow">Étape sélectionnée</span>
              </div>
              <div>
                <div data-info-time class="font-mono text-2xl text-accent tabular-nums mb-2 font-semibold">{r.points[0].horaires}</div>
                <h3 data-info-title class="mb-2">{r.points[0].titre}</h3>
                <p data-info-desc class="text-sm text-ink-muted leading-relaxed">{r.points[0].desc}</p>
              </div>
              <div class="mt-auto border-t border-border pt-4">
                <div class="eyebrow">Tous les points</div>
                <ol class="mt-3 grid grid-cols-1 gap-1.5 text-xs" data-info-list>
                  {r.points.map((p, i) => (
                    <li>
                      <button type="button" data-point={p.id} data-route={r.id}
                              class="w-full text-left flex items-center gap-2 py-1.5 px-2 rounded hover:bg-cream cursor-pointer">
                        <span class="w-5 h-5 shrink-0 rounded-full flex items-center justify-center font-mono text-[10px] font-bold text-white" style={`background:${r.couleur}`}>{i + 1}</span>
                        <span class="flex-1 truncate">{p.titre.replace('· ', '')}</span>
                        <span class="font-mono text-[10px] text-ink-muted">{p.horaires}</span>
                      </button>
                    </li>
                  ))}
                </ol>
              </div>
            </div>
          </div>
        </div>
      ))}
    </aside>
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-4 justify-between border-t border-border pt-6">
    <div class="text-sm text-ink-muted">
      Départ village <span class="font-semibold text-ink">Grand Place, Lille</span> · Métro Rihour (ligne 1)
    </div>
    <a href="/inscription" class="btn btn-primary !py-2.5">Réserver ma place</a>
  </div>
</section>

<script is:inline define:vars={{ routes }}>
  const toggle = document.getElementById('route-toggle');
  const tabs = toggle?.querySelectorAll('[data-route]');
  const showRoute = (id) => {
    // toggle btn active states
    tabs?.forEach((t) => {
      const active = t.getAttribute('data-route') === id;
      t.setAttribute('data-active', active ? 'true' : 'false');
      t.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    // toggle blocks visibility
    document.querySelectorAll('[data-route-stats]').forEach((el) => el.classList.toggle('hidden', el.getAttribute('data-route-stats') !== id));
    document.querySelectorAll('[data-route-info]').forEach((el)  => el.classList.toggle('hidden', el.getAttribute('data-route-info')  !== id));
    document.querySelectorAll('[data-route-path]').forEach((el)  => el.classList.toggle('hidden', el.getAttribute('data-route-path')  !== id));
    document.querySelectorAll('[data-route-points]').forEach((el)=> el.classList.toggle('hidden', el.getAttribute('data-route-points')!== id));
  };
  tabs?.forEach((t) => t.addEventListener('click', () => showRoute(t.getAttribute('data-route'))));

  const updateInfo = (routeId, pointId) => {
    const route = routes.find((r) => r.id === routeId);
    const point = route?.points.find((p) => p.id === pointId);
    if (!route || !point) return;
    const info = document.getElementById(`info-${routeId}`);
    if (!info) return;
    info.querySelector('[data-info-time]').textContent = point.horaires;
    info.querySelector('[data-info-title]').textContent = point.titre;
    info.querySelector('[data-info-desc]').textContent = point.desc;
  };
  document.querySelectorAll('[data-point]').forEach((el) => {
    el.addEventListener('click', () => updateInfo(el.getAttribute('data-route'), el.getAttribute('data-point')));
  });
</script>
