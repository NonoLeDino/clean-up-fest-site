---
import { temoignages } from '@/data/site';
---

<section class="section-cream">
  <div class="container-page py-24 lg:py-32">
    <div class="grid md:grid-cols-12 gap-8 items-end mb-14">
      <div class="md:col-span-8">
        <span class="eyebrow">Ils y étaient</span>
        <h2 class="mt-3">Ce qu'en disent<br/>les participants.</h2>
      </div>
      <div class="md:col-span-4 text-ink-muted text-sm md:text-right">
        Trois voix, trois entrées différentes,<br/>un même souvenir.
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-3 reveal-group">
      {temoignages.map((t, i) => (
        <figure class="card p-7 flex flex-col gap-6 reveal">
          <svg class="w-8 h-8 text-accent shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9 7c-3 1-5 3.5-5 7v3h6v-6H7c0-2 1-3.5 3-4V7zm10 0c-3 1-5 3.5-5 7v3h6v-6h-3c0-2 1-3.5 3-4V7z"/>
          </svg>
          <blockquote class="text-lg leading-relaxed text-ink flex-1">
            {t.quote}
          </blockquote>
          <figcaption class="flex items-center gap-3 pt-2 border-t border-border">
            <img src={t.photo} alt={`Portrait de ${t.nom}, ${t.role}`} class="w-12 h-12 rounded-full object-cover" loading="lazy"/>
            <div>
              <div class="font-semibold text-ink text-sm">{t.nom}</div>
              <div class="text-xs text-ink-muted">{t.role}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
