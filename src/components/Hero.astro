---
import Countdown from './Countdown.astro';
import { site } from '@/data/site';
---

<section class="relative isolate overflow-hidden text-white min-h-[100svh] flex items-stretch">
  <!-- Background image -->
  <img
    src="/media/photos/ai/cleanup-crowd-lille.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover scale-110"
    fetchpriority="high"
  />
  <!-- Overlays : dark gradient bottom-up + brand tint -->
  <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/50 to-black/85"></div>
  <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-tr from-primary/25 via-transparent to-accent/25 mix-blend-overlay"></div>
  <div aria-hidden="true" class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_20%,black_100%)] opacity-70"></div>

  <div class="relative container-page pt-24 pb-14 sm:pt-28 sm:pb-20 flex flex-col justify-between gap-12 w-full">
    <!-- Top row -->
    <div class="flex items-center justify-between text-[11px] sm:text-xs uppercase tracking-[0.24em] text-white/75 font-mono fade-in">
      <span class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-accent pulse-soft"></span>
        {site.edition}
      </span>
      <span class="hidden sm:inline">{site.lieu}</span>
      <span>By {site.organisateur}</span>
    </div>

    <!-- Center content -->
    <div class="flex flex-col items-center justify-center gap-8 flex-1 text-center">
      <h1 class="max-w-4xl font-display text-white text-balance leading-[0.95] fade-in">
        Rejoignez <span class="italic font-normal text-white/85">le</span> <span class="text-accent-glow">mouvement !</span>
      </h1>

      <p class="max-w-2xl text-base sm:text-lg text-white/80 leading-relaxed fade-in">
        {site.valeur}
      </p>

      <div class="flex flex-wrap gap-3 justify-center fade-in">
        <a href="/inscription?formule=marche" class="btn btn-primary">Je marche</a>
        <a href="/inscription?formule=course" class="btn btn-ghost">Je cours</a>
      </div>
    </div>

    <!-- Bottom bar : date + countdown + scroll cue -->
    <div class="grid gap-6 md:grid-cols-[1fr_auto] items-end fade-in">
      <div>
        <div class="eyebrow !text-white/60 mb-2">Rendez-vous</div>
        <div class="date-display text-white">
          19<span class="text-accent">.</span>09<span class="text-accent">.</span>26
        </div>
        <div class="mt-2 text-white/75 text-sm uppercase tracking-[0.2em]">
          Sam · Grand Place → Citadelle · 10h → 22h
        </div>
      </div>
      <div class="w-full md:w-auto md:min-w-[320px]">
        <div class="eyebrow !text-white/60 mb-2">Grand jour dans</div>
        <Countdown compact />
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/40 text-[10px] uppercase tracking-[0.24em] hidden md:flex flex-col items-center gap-2 font-mono">
    <span>Scroll</span>
    <span class="w-px h-8 bg-white/30"></span>
  </div>
</section>
