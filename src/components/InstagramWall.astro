---
import { igPosts } from '@/data/site';
---

<section class="container-page py-24 lg:py-32">
  <div class="grid md:grid-cols-12 gap-8 items-end mb-10">
    <div class="md:col-span-7">
      <span class="eyebrow">On se suit ?</span>
      <h2 class="mt-3">Suivez-nous<br/><span class="text-accent">@cleanupfest</span></h2>
    </div>
    <div class="md:col-span-5 flex md:justify-end items-center gap-3">
      <div class="flex -space-x-2">
        {[1,2,3,4].map((i) => (
          <img src={`/media/photos/portrait-${i}.jpg`} alt="" class="w-9 h-9 rounded-full border-2 border-bg object-cover"/>
        ))}
      </div>
      <div class="text-sm">
        <div class="font-semibold text-ink">+12K abonnés</div>
        <div class="text-xs text-ink-muted">Rejoignez la communauté</div>
      </div>
      <a href="#" class="btn btn-dark ml-3">Follow</a>
    </div>
  </div>

  <div class="grid gap-3 grid-cols-2 sm:grid-cols-3 reveal-group">
    {igPosts.map((p, i) => (
      <a href="#" class="group relative aspect-square rounded-lg overflow-hidden cursor-pointer isolate reveal">
        <img src={p.image} alt="" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy"/>

        <!-- Default overlay : subtle -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>

        <!-- Bottom meta -->
        <div class="absolute bottom-3 left-3 right-3 flex items-center justify-between text-white text-xs">
          <div class="flex items-center gap-1.5 font-semibold">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 21s-8-4.5-8-11a5 5 0 019-3 5 5 0 019 3c0 6.5-8 11-8 11z"/>
            </svg>
            {p.likes.toLocaleString('fr-FR')}
          </div>
          <span class="opacity-70 font-mono">il y a {p.days}j</span>
        </div>

        <!-- Hover overlay : caption -->
        <div class="absolute inset-0 bg-black/75 backdrop-blur-sm p-5 flex flex-col justify-between opacity-0 group-hover:opacity-100 transition-opacity duration-300 text-white">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-accent via-primary-glow to-accent-dark p-0.5">
              <div class="w-full h-full rounded-full bg-white flex items-center justify-center text-[10px] font-mono font-bold text-ink">CF</div>
            </div>
            <div>
              <div class="text-xs font-semibold">cleanupfest</div>
              <div class="text-[10px] opacity-70 font-mono">Lille · Fr</div>
            </div>
          </div>
          <p class="text-sm leading-relaxed">{p.caption}</p>
          <div class="flex items-center justify-between text-xs">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 21s-8-4.5-8-11a5 5 0 019-3 5 5 0 019 3c0 6.5-8 11-8 11z"/>
              </svg>
              {p.likes.toLocaleString('fr-FR')}
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
              </svg>
              {Math.round(p.likes / 12)}
            </span>
          </div>
        </div>

        {i === 0 && (
          <span class="absolute top-3 left-3 chip !bg-accent !text-white !text-[10px]">
            <span class="w-1.5 h-1.5 rounded-full bg-white pulse-soft"></span>
            Live
          </span>
        )}
      </a>
    ))}
  </div>
</section>
