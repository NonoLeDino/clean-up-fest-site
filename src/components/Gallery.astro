---
type Props = { preview?: boolean };
const { preview = false } = Astro.props;

const photos: Array<{ src: string; alt: string }> = [
  { src: '/media/photos/ai/cleanup-crowd-lille.jpg',     alt: "Foule engagée sur la Grand Place de Lille avec drapeaux verts et roses" },
  { src: '/media/photos/ai/march-2025-belfry.jpg',       alt: "Participants passant devant le Beffroi de Lille avec drapeaux" },
  { src: '/media/photos/ai/volunteers-team-lille.jpg',   alt: "Équipe de 5 bénévoles en gilets fluo ramassant des déchets à Lille" },
  { src: '/media/photos/ai/coat-to-homeless.jpg',        alt: "Bénévole donnant une doudoune verte à une personne sans-abri" },
  { src: '/media/photos/ai/foodtruck-festival.jpg',      alt: "Foodtruck festival avec queue de gourmands, ambiance dorée" },
  { src: '/media/photos/ai/march-2025-family.jpg',       alt: "Famille ramassant des déchets ensemble dans un parc lillois" },
  { src: '/media/photos/ai/march-2025-dj-crowd.jpg',     alt: "DJ à vélo entouré de danseurs et ramasseurs" },
  { src: '/media/photos/ai/march-2025-finish.jpg',       alt: "Coureurs à l'arrivée sous une arche Clean Up Fest, médailles" },
  { src: '/media/photos/ai/march-2025-selfie.jpg',       alt: "Selfie de groupe de bénévoles avec leurs sacs remplis" },
  { src: '/media/photos/ai/march-2025-cleanup.jpg',      alt: "Gros plan de mains ramassant un déchet sur les pavés de Lille" },
  { src: '/media/photos/ai/cigarette-butts-hand.jpg',    alt: "Main gantée tenant une pile de mégots ramassés" },
  { src: '/media/photos/ai/march-2025-beer.jpg',         alt: "Participants trinquant à la fin de la journée, ambiance conviviale" },
];
const items = preview ? photos.slice(0, 8) : photos;
---

<section class="container-page py-24 lg:py-32">
  <div class="flex items-end justify-between flex-wrap gap-4 mb-10">
    <div>
      <span class="eyebrow">Édition 2025</span>
      <h2 class="mt-3">Souvenirs de la dernière édition.</h2>
    </div>
    {preview && <a href="/galerie" class="btn btn-outline">Toute la galerie</a>}
  </div>

  <!-- Masonry-like grid : columns of variable heights -->
  <div class="columns-2 sm:columns-3 lg:columns-4 gap-3 [column-fill:_balance] space-y-3">
    {items.map((p, i) => (
      <div class="relative overflow-hidden rounded-lg break-inside-avoid group cursor-pointer">
        <img
          src={p.src}
          alt={p.alt}
          class:list={['w-full object-cover transition-transform duration-500 group-hover:scale-105',
            i % 5 === 0 ? 'aspect-[3/4]' : i % 5 === 1 ? 'aspect-square' : i % 5 === 2 ? 'aspect-[4/3]' : i % 5 === 3 ? 'aspect-[3/4]' : 'aspect-square']}
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
      </div>
    ))}
  </div>
</section>
