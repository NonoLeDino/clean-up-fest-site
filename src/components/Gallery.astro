---
type Props = { preview?: boolean };
const { preview = false } = Astro.props;

const photos: Array<{ src: string; alt: string }> = [
  { src: '/media/photos/beach-cleanup.jpg',    alt: "Rangée de bacs de tri sélectif jaune, bleu, rouge et vert" },
  { src: '/media/photos/dj-console.jpg',       alt: "DJ en action, bras levé face au public, fumée colorée" },
  { src: '/media/photos/pickup-plastic.jpg',   alt: "Poubelle urbaine décorée de fleurs, symbole de civisme" },
  { src: '/media/photos/festival-day.jpg',     alt: "Confettis et lumières sur le public d'une scène de festival" },
  { src: '/media/photos/volunteer.jpg',        alt: "Bénévole vu de dos, casquette rouge et t-shirt Volunteer" },
  { src: '/media/photos/running-crowd.jpg',    alt: "Groupe de coureurs au coucher du soleil, silhouettes en contre-jour" },
  { src: '/media/photos/foodtruck-real.jpg',   alt: "Burger épais et gourmand servi lors du festival" },
  { src: '/media/photos/dj-hands.jpg',         alt: "Portrait rapproché d'un DJ derrière son microphone" },
  { src: '/media/photos/runners-city.jpg',     alt: "Peloton de cyclistes en course dans la ville" },
  { src: '/media/photos/food-truck.jpg',       alt: "Terrasse extérieure illuminée de guirlandes, ambiance chaleureuse" },
  { src: '/media/photos/factory-pollution.jpg',alt: "Usine industrielle avec fumées, rappelant l'urgence écologique" },
  { src: '/media/photos/hero-crowd.jpg',       alt: "Foule bras levés face à une scène éclairée en concert" },
];
const items = preview ? photos.slice(0, 8) : photos;
---

<section class="container-page py-24 lg:py-32">
  <div class="flex items-end justify-between flex-wrap gap-4 mb-10">
    <div>
      <span class="eyebrow">Édition 2025</span>
      <h2 class="mt-3">Souvenirs de la dernière édition.</h2>
    </div>
    {preview && <a href="/galerie" class="btn btn-outline">Toute la galerie</a>}
  </div>

  <!-- Masonry-like grid : columns of variable heights -->
  <div class="columns-2 sm:columns-3 lg:columns-4 gap-3 [column-fill:_balance] space-y-3">
    {items.map((p, i) => (
      <div class="relative overflow-hidden rounded-lg break-inside-avoid group cursor-pointer">
        <img
          src={p.src}
          alt={p.alt}
          class:list={['w-full object-cover transition-transform duration-500 group-hover:scale-105',
            i % 5 === 0 ? 'aspect-[3/4]' : i % 5 === 1 ? 'aspect-square' : i % 5 === 2 ? 'aspect-[4/3]' : i % 5 === 3 ? 'aspect-[3/4]' : 'aspect-square']}
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
      </div>
    ))}
  </div>
</section>
