---
import Logo from './Logo.astro';
import { site, partenaires, nav } from '@/data/site';
---

<footer class="section-dark mt-0">
  <div class="container-page pt-20 pb-10">
    <!-- Big call sur date -->
    <div class="border-b border-white/10 pb-16 mb-16">
      <div class="grid md:grid-cols-12 gap-8 items-end">
        <div class="md:col-span-8">
          <div class="chip chip-dark mb-4">Rendez-vous</div>
          <div class="font-display font-semibold text-white leading-[0.9] text-6xl sm:text-8xl md:text-9xl">
            {site.dateAffichee}
          </div>
          <p class="mt-4 text-white/70 text-lg">{site.lieu} · {site.horaires}</p>
        </div>
        <div class="md:col-span-4 flex flex-col gap-3">
          <a href="/inscription?formule=marche" class="btn btn-primary w-full">Je marche</a>
          <a href="/inscription?formule=course" class="btn btn-ghost w-full">Je cours</a>
        </div>
      </div>
    </div>

    <!-- Colonnes -->
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2 flex flex-col gap-5">
        <Logo variant="green" size="md" glow />
        <p class="text-sm text-white/75 max-w-md leading-relaxed">
          Organisé par <span class="font-semibold text-white">{site.organisateur}</span> à {site.ville}.
          Un festival qui nettoie la ville en dansant.
        </p>
        <div class="flex flex-wrap gap-2">
          {site.social.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full border border-white/25 flex items-center justify-center hover:bg-white/10 transition-colors"
              aria-label={`${s.label} — ${s.handle} (nouvelle fenêtre)`}
            >
              <span class="text-white/80 text-xs font-semibold uppercase">{s.label[0]}</span>
            </a>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-xs uppercase tracking-widest text-white/50 font-semibold mb-4">Le festival</h3>
        <ul class="space-y-2.5">
          {nav.map((item) => (
            <li><a href={item.href} class="text-sm text-white/85 hover:text-accent transition-colors link-anim">{item.label}</a></li>
          ))}
          <li><a href="/inscription" class="text-sm text-white/85 hover:text-accent transition-colors link-anim">Inscription</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs uppercase tracking-widest text-white/50 font-semibold mb-4">Partenaires</h3>
        <ul class="space-y-2.5">
          {partenaires.slice(0, 6).map((p) => (
            <li>
              {p.href ? (
                <a href={p.href} target="_blank" rel="noopener noreferrer"
                   class="text-sm text-white/85 hover:text-accent transition-colors link-anim">
                  {p.nom}
                </a>
              ) : (
                <span class="text-sm text-white/85">{p.nom}</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bar bas -->
    <div class="border-t border-white/10 mt-16 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/50">
      <p>© {new Date().getFullYear()} {site.nom}. Tous droits réservés.</p>
      <p class="flex gap-4">
        <a href="#" class="hover:text-white">Mentions légales</a>
        <a href="#" class="hover:text-white">Politique de confidentialité</a>
        <a href="/#faq" class="hover:text-white">FAQ</a>
      </p>
    </div>
  </div>
</footer>
