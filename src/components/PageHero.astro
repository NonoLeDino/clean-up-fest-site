---
type Props = {
  eyebrow: string;
  title: string;
  desc?: string;
  photo: string;
  ratio?: 'square' | 'video' | 'wide';
};
const { eyebrow, title, desc, photo, ratio = 'wide' } = Astro.props;
const aspect = ratio === 'square' ? 'aspect-square' : ratio === 'video' ? 'aspect-video' : 'aspect-[21/9]';
---

<section class="relative">
  <div class:list={['relative', aspect, 'w-full overflow-hidden']}>
    <img src={photo} alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/60"></div>
    <div class="absolute inset-0 bg-gradient-to-tr from-primary/25 via-transparent to-accent/25 mix-blend-overlay"></div>
    <div class="absolute inset-0 flex items-end">
      <div class="container-page pb-14 sm:pb-20">
        <span class="chip !bg-white/15 !text-white !border !border-white/25 backdrop-blur">
          {eyebrow}
        </span>
        <h1 class="mt-4 text-white text-balance max-w-4xl">{title}</h1>
        {desc && <p class="mt-4 text-white/85 text-lg leading-relaxed max-w-2xl">{desc}</p>}
      </div>
    </div>
  </div>
</section>
